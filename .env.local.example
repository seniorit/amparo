# Copia este archivo a `.env.local` y rellena con tus claves de Supabase

# URL pública de Supabase (ej: https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública (anon) para uso en cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (SECRETA) para operaciones server-side (no exponer en cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Cadena de conexión Postgres (para Prisma u otros clientes DB). Obténla en Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
