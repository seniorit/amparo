model Psicologo {
  id                    String       @id @default(cuid())
  nombreCompleto        String       @map("nombre_completo")
  correo                String       @unique
  contrasenaHash        String       @map("contrasena_hash")
  whatsapp              String
  especialidades        String[]
  anosExperiencia       Int          @map("anos_experiencia")
  numeroColegiado       String       @map("numero_colegiado")
  paisResidencia        String       @map("pais_residencia")
  disponibilidadSemanal Json?        @map("disponibilidad_semanal")
  bio                   String?
  fotoUrl               String?      @map("foto_url")
  fotoIsPublic          Boolean      @default(true) @map("foto_is_public")
  estadoPerfil          EstadoPerfil @default(pendiente) @map("estado_perfil")
  rol                   RolUsuario   @default(psicologo)
  fechaRegistro         DateTime     @default(now()) @map("fecha_registro")
  citas                 Cita[]

  @@map("psicologos")
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  token       String   @unique
  correo      String
  psicologoId String   @map("psicologo_id")
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([correo])
  @@index([token])
  @@map("password_reset_tokens")
}

model Paciente {
  id                     String             @id @default(cuid())
  nombreCompleto         String             @map("nombre_completo")
  genero                 Genero
  correo                 String
  whatsapp               String
  estadoVenezuela        String             @map("estado_venezuela")
  motivoConsulta         String             @map("motivo_consulta")
  primeraVez             Boolean            @default(true) @map("primera_vez")
  preferenciaHorario     PreferenciaHorario @map("preferencia_horario")
  formaContactoPreferida String?            @map("forma_contacto_preferida")
  nivelUrgencia          NivelUrgencia      @default(media) @map("nivel_urgencia")
  comentariosAdicionales String?            @map("comentarios_adicionales")
  fechaRegistro          DateTime           @default(now()) @map("fecha_registro")
  citas                  Cita[]

  @@map("pacientes")
}

model Cita {
  id             String         @id @default(cuid())
  pacienteId     String         @map("paciente_id")
  psicologoId    String?        @map("psicologo_id")
  fechaSolicitud DateTime       @default(now()) @map("fecha_solicitud")
  fechaHoraCita  DateTime?      @map("fecha_hora_cita")
  origenWhatsapp OrigenWhatsapp @default(Web_Directo) @map("origen_whatsapp")
  estado         EstadoCita     @default(pendiente_asignar)
  notasInternas  String?        @map("notas_internas")
  metodoContacto String         @default("Llamada de WhatsApp") @map("metodo_contacto")
  paciente       Paciente       @relation(fields: [pacienteId], references: [id])
  psicologo      Psicologo?     @relation(fields: [psicologoId], references: [id])

  @@index([pacienteId])
  @@index([psicologoId])
  @@index([estado])
  @@map("citas")
}

enum EstadoPerfil {
  pendiente
  activo
  inactivo
}

enum RolUsuario {
  psicologo
  admin
}

enum Genero {
  masculino
  femenino
}

enum PreferenciaHorario {
  Manana
  Tarde
  Noche
}

enum NivelUrgencia {
  baja
  media
  alta
}

enum OrigenWhatsapp {
  Linea_Principal
  Linea_Apoyo
  Web_Directo
}

enum EstadoCita {
  pendiente_asignar
  confirmada
  completada
  cancelada
}
